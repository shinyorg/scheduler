<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scheduler="clr-namespace:Shiny.Maui.Scheduler;assembly=Shiny.Maui.Scheduler"
             xmlns:vm="clr-namespace:SampleApp.ViewModels"
             x:Class="SampleApp.Pages.AgendaPage"
             x:DataType="vm:AgendaViewModel"
             Title="Agenda">

    <Grid RowDefinitions="Auto,*">
        <Button Text="{Binding DaysToggleText}"
                Command="{Binding ToggleDaysCommand}"
                HorizontalOptions="End"
                Margin="8"
                BackgroundColor="DodgerBlue"
                TextColor="White"
                CornerRadius="8"
                FontSize="12" />

        <scheduler:SchedulerAgendaView Grid.Row="1"
            x:Name="AgendaView"
            Provider="{Binding Provider}"
            SelectedDate="{Binding SelectedDate}"
            DaysToShow="{Binding DaysToShow}"
            ShowCarouselDatePicker="True"
            ShowCurrentTimeMarker="True"
            CurrentTimeMarkerColor="Red"
            DefaultEventColor="CornflowerBlue"
            TimeSlotHeight="60" />
    </Grid>

</ContentPage>
