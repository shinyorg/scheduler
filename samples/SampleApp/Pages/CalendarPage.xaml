<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scheduler="clr-namespace:Shiny.Maui.Scheduler;assembly=Shiny.Maui.Scheduler"
             xmlns:vm="clr-namespace:SampleApp.ViewModels"
             x:Class="SampleApp.Pages.CalendarPage"
             x:DataType="vm:CalendarViewModel"
             Title="Calendar">

    <scheduler:SchedulerCalendarView
        Provider="{Binding Provider}"
        SelectedDate="{Binding SelectedDate}"
        DisplayMonth="{Binding DisplayMonth}"
        MaxEventsPerCell="3"
        CurrentDayColor="DodgerBlue"
        CalendarCellSelectedColor="LightBlue" />

</ContentPage>
