<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scheduler="clr-namespace:Shiny.Maui.Scheduler;assembly=Shiny.Maui.Scheduler"
             xmlns:vm="clr-namespace:SampleApp.ViewModels"
             x:Class="SampleApp.Pages.CalendarListPage"
             x:DataType="vm:CalendarListViewModel"
             Title="Event List">

    <scheduler:SchedulerCalendarListView
        Provider="{Binding Provider}"
        SelectedDate="{Binding SelectedDate}"
        DefaultEventColor="CornflowerBlue" />

</ContentPage>
